// Delivery Command Center — Prisma Schema
// Railway PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
//  ENUMS
// ─────────────────────────────────────────

enum Location {
  ONSITE
  OFFSHORE
}

enum EmploymentType {
  FT_EMPLOYEE
  PT_EMPLOYEE
  CONTRACTOR
  C2C
}

enum BgCheckStatus {
  NOT_REQUIRED
  PENDING
  CLEARED
  EXPIRED
}

enum ResourceStatus {
  DEPLOYED
  PARTIALLY_DEPLOYED
  AVAILABLE
  ON_BENCH
  EXITED
}

enum SowType {
  TM        // Time & Materials
  FIXED     // Fixed Price
}

enum BillingType {
  TM
  FIXED_MONTHLY
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  ON_HOLD
  COMPLETED
  TERMINATED
}

enum PipelineStage {
  DISCOVERY
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

// ─────────────────────────────────────────
//  MASTER DATA
// ─────────────────────────────────────────

model Skill {
  id        String          @id @default(cuid())
  name      String          @unique
  submods   String[]        // array of sub-module names
  sortOrder Int             @default(0)
  resources Resource[]      @relation("PrimarySkill")
  secSkills ResourceSkill[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model Currency {
  code      String   @id           // USD, INR, EUR
  symbol    String                 // $, ₹, €
  name      String                 // US Dollar, Indian Rupee
  rateVsUSD Float    @default(1)   // 1 USD = rateVsUSD units of this currency
  isBase    Boolean  @default(false)
  updatedAt DateTime @updatedAt
}

model SystemConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────
//  RESOURCE
// ─────────────────────────────────────────

model Resource {
  id             String         @id @default(cuid())

  // Identity
  name           String
  empId          String?        // payroll/HRMS reference
  email          String?
  phone          String?

  // Employment
  location       Location
  employmentType EmploymentType
  joiningDate    DateTime?      // FT/PT
  contractStart  DateTime?      // Contractor/C2C
  contractEnd    DateTime?      // Contractor/C2C — triggers alert
  noticePeriod   Int?           // days: 15, 30, 60, 90
  rolloffDate    DateTime?      // triggers bench planning alert

  // Compliance
  visaType       String?        // H1B, OPT, GC, Citizen, L1, NA
  visaExpiry     DateTime?      // alert 60 days before
  bgCheckStatus  BgCheckStatus  @default(NOT_REQUIRED)

  // Skills
  primarySkillId String
  primarySkill   Skill          @relation("PrimarySkill", fields: [primarySkillId], references: [id])
  primarySubmods String[]       // sub-module names from primarySkill.submods
  secondarySkills ResourceSkill[]

  // Cost — current active values (history in CostHistory)
  costInput      Float          // CTC or rate depending on type
  rateCurrency   String         @default("INR") // INR | USD — for offshore contractor/C2C
  paymentTerms   String         // Monthly Payroll | Net 30 | Net 60
  payCurrency    String         @default("INR")

  // Computed status (can be derived but stored for query performance)
  status         ResourceStatus @default(AVAILABLE)
  benchSince     DateTime?

  // Relations
  costHistory    CostHistory[]
  deployments    Deployment[]

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([status])
  @@index([primarySkillId])
  @@index([location, employmentType])
}

// Secondary skills with their own sub-modules per resource
model ResourceSkill {
  id         String   @id @default(cuid())
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  resourceId String
  skill      Skill    @relation(fields: [skillId], references: [id])
  skillId    String
  submods    String[] // sub-modules for THIS skill on THIS resource

  @@unique([resourceId, skillId])
}

// Point-in-time cost history — append only, never deleted
model CostHistory {
  id            String    @id @default(cuid())
  resource      Resource  @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  resourceId    String
  effectiveFrom DateTime
  effectiveTo   DateTime? // null = currently active
  inputValue    Float     // the CTC or rate entered
  inputCurrency String    // INR | USD
  fxSnapshot    Float     // FX rate locked at time of entry
  computedUSDhr Float     // locked computed rate — used for historical P&L
  reason        String    // Joining | Increment | Renegotiation | Promotion | Correction

  createdAt     DateTime  @default(now())

  @@index([resourceId, effectiveFrom])
}

// ─────────────────────────────────────────
//  PROJECTS / SOW
// ─────────────────────────────────────────

model Project {
  id          String        @id @default(cuid())
  client      String
  name        String
  sowNumber   String?       @unique
  sowType     SowType
  currency    String        @default("USD")
  startDate   DateTime
  endDate     DateTime
  status      ProjectStatus @default(ACTIVE)

  // Optional SOW metadata
  clientRef   String?       // client PO / reference number
  clientContact String?
  notes       String?

  // Project team (links to User)
  pmUserId    String?       // Project Manager
  amUserId    String?       // Account Manager
  dmUserId    String?       // Delivery Manager
  pm          User?         @relation("ProjectPM", fields: [pmUserId], references: [id])
  am          User?         @relation("ProjectAM", fields: [amUserId], references: [id])
  dm          User?         @relation("ProjectDM", fields: [dmUserId], references: [id])

  // For fixed price — NTE cap for T&M or total contract value
  totalValue  Float?

  // Relations
  roles       Role[]
  milestones  Milestone[]   // fixed price billing milestones
  parentId    String?       // for addendums — links to parent SOW
  parent      Project?      @relation("Addendums", fields: [parentId], references: [id])
  addendums   Project[]     @relation("Addendums")

  // Pipeline link (if converted from opportunity)
  opportunityId String?     @unique
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id])

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status])
  @@index([client])
}

model Role {
  id          String      @id @default(cuid())
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  title       String
  skillId     String?     // expected skill for this role
  billRate    Float?      // USD/hr for T&M
  billingType BillingType @default(TM)
  fixedAmount Float?      // for FIXED_MONTHLY billing type
  planStart   DateTime
  planEnd     DateTime
  deployments Deployment[]

  @@index([projectId])
}

// Fixed-price billing milestones
model Milestone {
  id            String    @id @default(cuid())
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId     String
  name          String    // "Phase 1 — Requirements Signoff"
  plannedDate   DateTime
  plannedAmount Float
  actualDate    DateTime?
  actualAmount  Float?
  invoiceDate   DateTime?
  paymentDate   DateTime?
  status        String    @default("UPCOMING") // UPCOMING | INVOICED | RECEIVED | OVERDUE

  @@index([projectId])
}

// ─────────────────────────────────────────
//  DEPLOYMENTS & ACTUALS
// ─────────────────────────────────────────

// One resource assigned to one role for a date range at an allocation %
// Multiple deployments per role = sequential resource assignment
model Deployment {
  id            String    @id @default(cuid())
  role          Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)
  roleId        String
  resource      Resource  @relation(fields: [resourceId], references: [id])
  resourceId    String
  startDate     DateTime
  endDate       DateTime
  allocation    Int       // 0-100 percent
  actuals       Actual[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([resourceId])
  @@index([roleId])
}

// Monthly actuals — entered by PM/admin, approved externally
// One row per deployment per month
model Actual {
  id            String     @id @default(cuid())
  deployment    Deployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade)
  deploymentId  String
  month         String     // "2025-06" — YYYY-MM format
  actualHours   Float
  enteredBy     String?
  notes         String?

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@unique([deploymentId, month])  // one entry per deployment per month
  @@index([month])
}

// ─────────────────────────────────────────
//  PIPELINE
// ─────────────────────────────────────────

model Opportunity {
  id               String        @id @default(cuid())
  client           String
  name             String
  stage            PipelineStage @default(DISCOVERY)
  probability      Int           @default(50)
  source           String?
  accountManagerId String?
  startDate        DateTime?
  endDate          DateTime?
  targetMargin     Float         @default(30)
  currency         String        @default("USD")
  convertedAt      DateTime?
  owner            String?
  notes            String?
  roles            OppRole[]
  project          Project?

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([stage])
}

model OppRole {
  id               String      @id @default(cuid())
  opportunity      Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  opportunityId    String
  title            String
  location         String      @default("OFFSHORE")  // OFFSHORE | ONSITE
  ftPt             String      @default("FT")         // FT | PT | CONTRACT
  experienceLevel  String?     // JUNIOR | MEDIUM | SENIOR
  yearsExp         Int?
  totalHours       Float?      // planned hours for engagement
  billRate         Float?      // USD/hr
  costGuidance     Float?      // USD/hr cost target
  costOverride     Boolean     @default(false)
  status           String      @default("OPEN") // OPEN | IDENTIFIED | CONFIRMED
  resourceId       String?     // link to Resource if identified
  resourceName     String?     // free text if not in roster
  notes            String?
  // Legacy fields kept for compatibility
  skillId          String?
  estStartDate     DateTime?
  durationMonths   Int         @default(6)
  hoursPerMonth    Int         @default(168)
}

// ─────────────────────────────────────────
//  AUTH & RBAC
// ─────────────────────────────────────────

enum AccessLevel {
  FULL
  READ
  NONE
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
}

model AppRole {
  id          String            @id @default(cuid())
  name        String            @unique
  label       String
  description String?
  isSystem    Boolean           @default(false)
  permissions Permission[]
  fieldPerms  FieldPermission[]
  users       User[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model Permission {
  id      String     @id @default(cuid())
  role    AppRole    @relation(fields: [roleId], references: [id], onDelete: Cascade)
  roleId  String
  module  String
  access  AccessLevel @default(NONE)

  @@unique([roleId, module])
}

model FieldPermission {
  id       String  @id @default(cuid())
  role     AppRole @relation(fields: [roleId], references: [id], onDelete: Cascade)
  roleId   String
  fieldKey String
  visible  Boolean @default(false)

  @@unique([roleId, fieldKey])
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  passwordHash  String
  role          AppRole   @relation(fields: [roleId], references: [id])
  roleId        String
  active        Boolean   @default(true)
  mustChangePwd Boolean   @default(false)
  mfaEnabled    Boolean   @default(false)
  mfaSecret     String?
  lastLogin     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  auditLogs     AuditLog[]
  projectsPM    Project[]  @relation("ProjectPM")
  projectsDM    Project[]  @relation("ProjectDM")
  projectsAM    Project[]  @relation("ProjectAM")

  @@index([email])
  @@index([roleId])
}

model Session {
  id           String   @id @default(cuid())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  refreshToken String   @unique
  ipAddress    String?
  userAgent    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([refreshToken])
}

model AuditLog {
  id          String      @id @default(cuid())
  user        User?       @relation(fields: [userId], references: [id])
  userId      String?
  userEmail   String?
  action      AuditAction
  module      String
  recordId    String?
  recordLabel String?
  oldValues   Json?
  newValues   Json?
  ipAddress   String?
  createdAt   DateTime    @default(now())

  @@index([userId])
  @@index([module])
  @@index([createdAt])
}

model Person {
  id        String   @id @default(cuid())
  name      String
  role      String
  email     String?
  phone     String?
  notes     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
