// Delivery Command Center — Prisma Schema
// Railway PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
//  ENUMS
// ─────────────────────────────────────────

enum Location {
  ONSITE
  OFFSHORE
}

enum EmploymentType {
  FT_EMPLOYEE
  PT_EMPLOYEE
  CONTRACTOR
  C2C
}

enum BgCheckStatus {
  NOT_REQUIRED
  PENDING
  CLEARED
  EXPIRED
}

enum ResourceStatus {
  DEPLOYED
  PARTIALLY_DEPLOYED
  AVAILABLE
  ON_BENCH
  EXITED
}

enum SowType {
  TM
  FIXED
}

enum BillingType {
  TM
  FIXED_MONTHLY
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  ON_HOLD
  COMPLETED
  TERMINATED
}

enum PipelineStage {
  QUALIFYING
  PROPOSED
  NEGOTIATING
  WON
  LOST
}

enum PersonRole {
  ACCOUNT_MANAGER
  DELIVERY_MANAGER
}

enum RoleStatus {
  OPEN
  IDENTIFIED
  CONFIRMED
}

enum ExperienceLevel {
  JUNIOR
  MEDIUM
  SENIOR
}

enum OppSource {
  EXISTING_ACCOUNT
  REFERRAL
  RFP
  COLD_OUTREACH
  PARTNER
}

// ─────────────────────────────────────────
//  MASTER DATA
// ─────────────────────────────────────────

model Skill {
  id        String          @id @default(cuid())
  name      String          @unique
  submods   String[]
  sortOrder Int             @default(0)
  resources Resource[]      @relation("PrimarySkill")
  secSkills ResourceSkill[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model Currency {
  code      String   @id
  symbol    String
  name      String
  rateVsUSD Float    @default(1)
  isBase    Boolean  @default(false)
  updatedAt DateTime @updatedAt
}

model SystemConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// Team — Account Managers and Delivery Managers
model Person {
  id        String     @id @default(cuid())
  name      String
  role      PersonRole
  email     String?
  phone     String?
  notes     String?
  active    Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([role])
}

// ─────────────────────────────────────────
//  RESOURCE
// ─────────────────────────────────────────

model Resource {
  id             String         @id @default(cuid())
  name           String
  empId          String?
  email          String?
  phone          String?
  location       Location
  employmentType EmploymentType
  joiningDate    DateTime?
  contractStart  DateTime?
  contractEnd    DateTime?
  noticePeriod   Int?
  rolloffDate    DateTime?
  visaType       String?
  visaExpiry     DateTime?
  bgCheckStatus  BgCheckStatus  @default(NOT_REQUIRED)
  primarySkillId String
  primarySkill   Skill          @relation("PrimarySkill", fields: [primarySkillId], references: [id])
  primarySubmods String[]
  secondarySkills ResourceSkill[]
  costInput      Float
  rateCurrency   String         @default("INR")
  paymentTerms   String
  payCurrency    String         @default("INR")
  status         ResourceStatus @default(AVAILABLE)
  benchSince     DateTime?
  costHistory    CostHistory[]
  deployments    Deployment[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([status])
  @@index([primarySkillId])
  @@index([location, employmentType])
}

model ResourceSkill {
  id         String   @id @default(cuid())
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  resourceId String
  skill      Skill    @relation(fields: [skillId], references: [id])
  skillId    String
  submods    String[]

  @@unique([resourceId, skillId])
}

model CostHistory {
  id            String    @id @default(cuid())
  resource      Resource  @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  resourceId    String
  effectiveFrom DateTime
  effectiveTo   DateTime?
  inputValue    Float
  inputCurrency String
  fxSnapshot    Float
  computedUSDhr Float
  reason        String
  createdAt     DateTime  @default(now())

  @@index([resourceId, effectiveFrom])
}

// ─────────────────────────────────────────
//  PROJECTS / SOW
// ─────────────────────────────────────────

model Project {
  id            String        @id @default(cuid())
  client        String
  name          String
  sowNumber     String?       @unique
  sowType       SowType
  currency      String        @default("USD")
  startDate     DateTime
  endDate       DateTime
  status        ProjectStatus @default(ACTIVE)
  clientRef     String?
  clientContact String?
  deliveryMgr   String?
  accountMgr    String?
  notes         String?
  totalValue    Float?
  roles         Role[]
  milestones    Milestone[]
  parentId      String?
  parent        Project?      @relation("Addendums", fields: [parentId], references: [id])
  addendums     Project[]     @relation("Addendums")
  opportunityId String?       @unique
  opportunity   Opportunity?  @relation(fields: [opportunityId], references: [id])
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([status])
  @@index([client])
}

model Role {
  id          String      @id @default(cuid())
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  title       String
  skillId     String?
  billRate    Float?
  billingType BillingType @default(TM)
  fixedAmount Float?
  planStart   DateTime
  planEnd     DateTime
  deployments Deployment[]

  @@index([projectId])
}

model Milestone {
  id            String    @id @default(cuid())
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId     String
  name          String
  plannedDate   DateTime
  plannedAmount Float
  actualDate    DateTime?
  actualAmount  Float?
  invoiceDate   DateTime?
  paymentDate   DateTime?
  status        String    @default("UPCOMING")

  @@index([projectId])
}

// ─────────────────────────────────────────
//  DEPLOYMENTS & ACTUALS
// ─────────────────────────────────────────

model Deployment {
  id            String    @id @default(cuid())
  role          Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)
  roleId        String
  resource      Resource  @relation(fields: [resourceId], references: [id])
  resourceId    String
  startDate     DateTime
  endDate       DateTime
  allocation    Int
  actuals       Actual[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([resourceId])
  @@index([roleId])
}

model Actual {
  id            String     @id @default(cuid())
  deployment    Deployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade)
  deploymentId  String
  month         String
  actualHours   Float
  enteredBy     String?
  notes         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@unique([deploymentId, month])
  @@index([month])
}

// ─────────────────────────────────────────
//  PIPELINE
// ─────────────────────────────────────────

model Opportunity {
  id              String        @id @default(cuid())
  client          String
  name            String
  source          OppSource     @default(EXISTING_ACCOUNT)
  accountManagerId String?
  stage           PipelineStage @default(QUALIFYING)
  probability     Int           @default(20)
  startDate       DateTime?
  endDate         DateTime?
  targetMargin    Float         @default(35)  // percent e.g. 35 = 35%
  currency        String        @default("USD")
  notes           String?
  convertedAt     DateTime?     // set when converted to SOW
  roles           OppRole[]
  project         Project?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([stage])
  @@index([client])
}

model OppRole {
  id              String         @id @default(cuid())
  opportunity     Opportunity    @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  opportunityId   String
  title           String
  location        Location       @default(OFFSHORE)
  ftPt            String         @default("Full-Time")  // Full-Time | Part-Time
  experienceLevel ExperienceLevel @default(MEDIUM)
  yearsExp        String?        // "7-10", "10+", "3-7"
  totalHours      Float?
  billRate        Float?         // estimated $/hr
  costGuidance    Float?         // auto or manual override
  costOverride    Boolean        @default(false)  // true = manual override
  status          RoleStatus     @default(OPEN)
  resourceName    String?        // free text OR name of matched resource
  resourceId      String?        // link to Resource if in roster
  notes           String?
  sortOrder       Int            @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([opportunityId])
}
